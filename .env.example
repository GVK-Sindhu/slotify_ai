# API Connection Settings (Toggle real api backend)
# Set to 'true' to connect to the docker-compose .NET API.
# Set to 'false' to run in standalone local simulation mode.
VITE_USE_REAL_API=false
VITE_API_URL=http://localhost:5000/api

# Backend environment settings (Docker Compose configuration)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=slotify_db
JWT_SECRET=SlotifyAiSuperSecretKeyForDevelopmentPurposes12345!
